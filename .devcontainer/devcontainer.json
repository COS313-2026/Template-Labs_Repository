{
    "name": "COS313 - Youth Sports Database Workspace",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "forwardPorts": [
        5432
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "cweijan.dbclient-jdbc"
            ]
        }
    },

    "postCreateCommand": "bash .devcontainer/setup_db.sh",
    "remoteUser": "vscode"
}